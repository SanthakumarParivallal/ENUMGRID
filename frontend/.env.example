# Copy to `.env.local` to override. Vite only exposes VITE_*-prefixed vars.

# Data source for the dashboard:
#   unset / false  -> live FastAPI SSE stream at /api/scan/stream
#                     (auto-falls back to the mock engine if the backend is down)
#   true           -> always use the offline mock engine (no backend needed)
VITE_USE_MOCK=false
