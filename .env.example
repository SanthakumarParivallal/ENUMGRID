# EnumGrid configuration — copy to ".env" and fill in. `start.sh` loads it
# automatically and passes it to the backend (also through `sudo` for --accurate-os).
# The real ".env" is gitignored, so secrets never get committed.

# --- CVE intelligence ------------------------------------------------------- #
# Free NVD API key (https://nvd.nist.gov/developers/request-an-api-key).
# Raises the live-CVE rate limit from 5 to 50 requests / 30s — strongly
# recommended when scanning many new hosts at once.
# Tip: you can also paste the key in the dashboard — it persists across restarts
# (owner-only, git-ignored file). This env var, if set, takes precedence.
ENUMGRID_NVD_API_KEY=

# Set to 1 to disable live NVD lookups (the local cache + offline DB still work).
# ENUMGRID_NVD_DISABLE=0
# Local CVE cache freshness (days) and per-host live-lookup time budget (seconds).
# ENUMGRID_CVE_TTL_DAYS=30
# ENUMGRID_NVD_BUDGET=20

# --- API safety / access ---------------------------------------------------- #
# Require a token on every request (only needed if you expose the API beyond
# localhost). Clients then pass ?token=... or "Authorization: Bearer ...".
# ENUMGRID_API_TOKEN=

# Allow scanning public/internet-routable targets (default: refused). Authorized
# use ONLY — leave unset unless you have explicit written permission.
# ENUMGRID_ALLOW_PUBLIC=0

# Concurrency + scope caps.
# ENUMGRID_MAX_SCANS=4
# ENUMGRID_MAX_HOSTS=4096

# Brute-force throttle: lock a REMOTE ip out after too many failed auth attempts
# in a window (loopback/local peers are exempt). Defaults shown.
# ENUMGRID_AUTH_MAX_FAILURES=8
# ENUMGRID_AUTH_WINDOW=300
# ENUMGRID_AUTH_LOCKOUT=900

# --- Observability ---------------------------------------------------------- #
# Structured logs (one JSON line per event) with request/scan correlation ids.
# ENUMGRID_LOG_LEVEL=INFO      # DEBUG | INFO | WARNING | ERROR
# ENUMGRID_LOG_FORMAT=json     # 'json' (machine) or 'text' (human-readable)

# --- Privilege elevation ---------------------------------------------------- #
# When the backend runs unprivileged, the dashboard's "Privilege" control can
# elevate the session to real SYN/UDP/OS-detection scans by validating a sudo
# password (kept in memory only). Set to 0 to forbid this entirely (scans then
# only ever auto-adapt to unprivileged equivalents).
# ENUMGRID_AUTO_SUDO=1

# --- Discovery tuning ------------------------------------------------------- #
# Discover mode runs a fast TCP connect-scan of the common ports so the grid
# shows open ports with no nmap/root. Set 0 to skip it; tune the per-port timeout.
# ENUMGRID_DISCOVER_PORTS=1
# ENUMGRID_PORT_TIMEOUT=0.5
# How long to listen for mDNS/Bonjour and SSDP/UPnP name announcements (seconds).
# Longer = more device names resolved, at the cost of a slightly longer scan.
# ENUMGRID_MDNS_SECS=6.0
# ENUMGRID_SSDP_SECS=2.5
