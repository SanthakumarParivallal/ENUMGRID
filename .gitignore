# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# ---- Node / frontend ----
node_modules/
frontend/dist/
frontend/.vite/
*.local

# ---- Tool output ----
# Scan reports + exports are operator data; never commit them.
enumgrid_*.json
enumgrid_*.html
enumgrid_*.csv
*.rdb

# ---- Scan history database (local operator data) ----
*.db
*.sqlite
*.sqlite3

# ---- Scheduled-scan rules (local operator data) ----
backend/schedules.json

# ---- OUI cache (large, downloadable) ----
oui.csv
oui.txt

# ---- secrets / local config (keep .env.example tracked) ----
.env
.certs/
# NVD API key persisted from the dashboard (owner-only file, never committed)
.enumgrid_nvd_key
# Copilot LLM keys + provider choice, persisted from the dashboard (owner-only)
.enumgrid_anthropic_key
.enumgrid_openai_key
.enumgrid_copilot_provider

# ---- runtime logs + local intel caches (operator data) ----
*.log
.backend.log
.frontend.log
enumgrid_kev.json

# ---- Editor / OS noise ----
.DS_Store
.idea/
.vscode/
*.swp

# ---- Machine-local Claude settings (keep launch.json, ignore local perms) ----
.claude/settings.local.json
.hypothesis/
